# Ollama configuration — local LLM inference server
OLLAMA_HOST=http://localhost:11434

# The LLM model to use via Ollama (must be pulled first: `ollama pull qwen2.5:7b`)
LLM_MODEL=qwen2.5:7b

# Target API base URL (override per campaign)
TARGET_API_URL=http://localhost:8080

# Fuzzing campaign settings
FUZZ_MAX_REQUESTS=500
FUZZ_TIME_BUDGET_SECONDS=300
FUZZ_STRATEGY=dictionary   # options: dictionary | llm | llm_guided

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs

# Results output
RESULTS_DIR=./results
